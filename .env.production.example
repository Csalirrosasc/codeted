# CodeTED - Variables de Entorno de Produccion
# Copia este archivo como .env en el servidor y reemplaza todos los valores

# ===========================================================
# PostgreSQL
# ===========================================================
POSTGRES_DB=codeted
POSTGRES_USER=codeted_user
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_DB

# ===========================================================
# Backend
# ===========================================================
SPRING_PROFILES_ACTIVE=prod
JWT_SECRET=CAMBIAR_SECRETO_LARGO_Y_UNICO_BASE64
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000
CORS_ALLOWED_ORIGINS=https://app.tudominio.com
AUTH_RATE_LIMIT_PER_MINUTE=12
CONTACT_RATE_LIMIT_PER_MINUTE=20

# ===========================================================
# Frontend / Public URLs
# ===========================================================
NEXT_PUBLIC_API_URL=https://api.tudominio.com/api
NEXT_PUBLIC_SITE_URL=https://app.tudominio.com

# ===========================================================
# Host Ports
# ===========================================================
BACKEND_PORT=8080
FRONTEND_PORT=3000
