# Backend — Variables de Entorno
# Copia este archivo como .env y configura los valores reales

# ===========================================================
# Spring Boot
# ===========================================================

# Perfil activo: dev | prod
SPRING_PROFILES_ACTIVE=dev

# ===========================================================
# Base de Datos — PostgreSQL
# ===========================================================

# Formato: jdbc:postgresql://<host>:<port>/<database>
DATABASE_URL=jdbc:postgresql://localhost:5432/codeted

DATABASE_USERNAME=codeted_user
DATABASE_PASSWORD=codeted_password

# ===========================================================
# Seguridad — JWT
# ===========================================================

# Clave secreta Base64 (HS256 de mínimo 512 bits)
# NUNCA committear la clave real de producción a Git
JWT_SECRET=MzQ4OTM5ODQ3Mjk4NDczMjk4NzQyOTgzNzQ5Mjg3MzQ5ODI3NDM5ODI3NDM5ODI3NDM5ODc0OTI4NzM0OTgyNzQzOTgyNzQ=

# Tiempo de expiración del token en milisegundos (por defecto: 86400000 = 24h)
JWT_EXPIRATION_MS=86400000
