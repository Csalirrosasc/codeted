# CodeTED - Variables de Entorno para DuckDNS
# Usa esta plantilla si publicarás con un solo dominio DuckDNS

# ===========================================================
# PostgreSQL
# ===========================================================
POSTGRES_DB=codeted
POSTGRES_USER=codeted_user
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_DB

# ===========================================================
# Backend
# ===========================================================
SPRING_PROFILES_ACTIVE=prod
JWT_SECRET=CAMBIAR_SECRETO_LARGO_Y_UNICO_BASE64
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000
CORS_ALLOWED_ORIGINS=https://codeted.duckdns.org
AUTH_RATE_LIMIT_PER_MINUTE=12
CONTACT_RATE_LIMIT_PER_MINUTE=20

# ===========================================================
# Frontend / Public URLs
# ===========================================================
NEXT_PUBLIC_API_URL=https://codeted.duckdns.org/api
NEXT_PUBLIC_SITE_URL=https://codeted.duckdns.org

# ===========================================================
# Host Ports
# ===========================================================
BACKEND_PORT=8080
FRONTEND_PORT=3000
