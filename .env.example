# CodeTED — Variables de Entorno (Raíz)
# Usadas por docker-compose.yml
# Copia este archivo como .env y rellena los valores reales

# ===========================================================
# PostgreSQL
# ===========================================================

POSTGRES_DB=codeted
POSTGRES_USER=codeted_user
POSTGRES_PASSWORD=codeted_password

# ===========================================================
# pgAdmin
# ===========================================================

PGADMIN_DEFAULT_EMAIL=admin@codeted.com
PGADMIN_DEFAULT_PASSWORD=admin123

# ===========================================================
# Backend
# ===========================================================

SPRING_PROFILES_ACTIVE=dev
JWT_SECRET=MzQ4OTM5ODQ3Mjk4NDczMjk4NzQyOTgzNzQ5Mjg3MzQ5ODI3NDM5ODI3NDM5ODI3NDM5ODc0OTI4NzM0OTgyNzQzOTgyNzQ=
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000
CORS_ALLOWED_ORIGINS=http://localhost:3000
AUTH_RATE_LIMIT_PER_MINUTE=12
CONTACT_RATE_LIMIT_PER_MINUTE=20

# ===========================================================
# Frontend Production
# ===========================================================

NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000
